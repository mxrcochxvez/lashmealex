{
  "name": "lashmealex",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "next dev",
    "build:next": "next build --webpack",
    "build": "opennextjs-cloudflare build",
    "build:worker": "opennextjs-cloudflare build",
    "start": "next start",
    "preview": "pnpm build:worker && wrangler dev",
    "deploy": "pnpm build:worker && wrangler deploy",
    "lint": "eslint src drizzle.config.ts eslint.config.mjs next.config.ts postcss.config.js tailwind.config.js",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:seed:local": "wrangler d1 execute DB --local --file=seed.sql",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:seed:remote": "wrangler d1 execute DB --remote --file=seed.sql"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260412.1",
    "@opennextjs/cloudflare": "^1.19.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "wrangler": "^4.81.1"
  }
}
